    "test:guided": "node .claude/test_guided-set-rest.mjs",
    "test:unit": "node --import tsx --test .claude/test_tempo.mjs .claude/test_guided-timer.mjs .claude/test_pt-report.mjs .claude/test_muscle-groups.mjs .claude/test_fake-supabase.mjs .claude/test_action-guards.mjs .claude/test_set-list-ops.mjs .claude/test_expand-template.mjs .claude/test_derive-initial-sets.mjs .claude/test_dal-cores.mjs .claude/test_save-queue.mjs .claude/test_atomic-persistence.mjs .claude/test_action-validation.mjs .claude/test_report-grouping.mjs .claude/test_local-date.mjs .claude/test_no-utc-calendar-dates.mjs .claude/test_local-date-action-sites.mjs .claude/test_wake-lock.mjs .claude/test_modal-focus.mjs .claude/test_modal-stack.mjs .claude/test_duplicate-workout-guard.mjs",
    "test:checklist": "node .claude/verify_checklist.mjs",
    "test:touch-targets": "node .claude/test_touch-targets.mjs",
    "test:filters": "node --experimental-strip-types --test .claude/test_exercise-picker-muscle-filter.mjs",
    "seed:exercises": "tsx scripts/seed-exercises.ts",
    "exercises:fetch-wger": "tsx scripts/fetch-wger.ts",
    "exercises:merge": "tsx scripts/merge-exercises.ts",
    "exercises:verify": "tsx scripts/verify-exercises.ts",
    "exercises:normalize-categories": "tsx scripts/normalize-categories.ts",
    "exercises:seed-bodyweight": "tsx scripts/seed-bodyweight.ts",
    "exercises:import": "npm run exercises:fetch-wger && npm run exercises:merge && npm run exercises:verify && npm run seed:exercises"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
